# ── 启用来源 ─────────────────────────────────────────────────
# 逗号分隔，可选 twitter,substack
ENABLED_SOURCES=twitter,substack

# ── Twitter 采集 ──────────────────────────────────────────────
# 代理设置（用于 twitter-cli，默认 http://127.0.0.1:6152）
TWITTER_PROXY=http://127.0.0.1:6152

# twitterapi.io API Key（备用数据源，注册后在 Dashboard 获取：https://twitterapi.io）
TWITTERAPI_KEY=

# 要采集的 Twitter 列表 ID
TWITTER_LIST_ID=

# ── AI 主路径（OpenAI）────────────────────────────────────────
# 填写后优先使用 OpenAI API；留空则自动切换到备用路径
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
SUBSTACK_READER_MODEL=gpt-4o-mini

# ── AI 备用路径（第三方 API 聚合商）─────────────────────────────
# 当 OPENAI_API_KEY 为空时启用，兼容 OpenAI 格式的聚合商
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# ── Obsidian ─────────────────────────────────────────────────
# Obsidian Vault 的绝对路径，生成的日刊 Markdown 将保存至此目录
# 示例：/Users/yourname/Documents/MyVault/daily-news
OBSIDIAN_VAULT_PATH=

# ── Substack ─────────────────────────────────────────────────
# 用于读取你公开个人页展示的 followed publications，并抓取它们的公开 RSS
# 你的 Substack 发布地址，如 https://yourname.substack.com
SUBSTACK_PUBLICATION_URL=
SUBSTACK_SOURCE_MAX_POSTS=40
SUBSTACK_SOURCE_MAX_POSTS_PER_PUBLICATION=2
