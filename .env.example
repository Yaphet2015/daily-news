# ── Twitter 采集 ──────────────────────────────────────────────
# twitterapi.io API Key（注册后在 Dashboard 获取：https://twitterapi.io）
TWITTERAPI_KEY=

# 要采集的 Twitter 列表 ID（默认已填入 AI/Tech 推荐列表）
TWITTER_LIST_ID=1602502639287435265

# ── AI 主路径（OpenAI）────────────────────────────────────────
# 填写后优先使用 OpenAI API；留空则自动切换到备用路径
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── AI 备用路径（第三方 API 聚合商）─────────────────────────────
# 当 OPENAI_API_KEY 为空时启用，兼容 OpenAI 格式的聚合商
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# ── Obsidian ─────────────────────────────────────────────────
# Obsidian Vault 的绝对路径，生成的日刊 Markdown 将保存至此目录
# 示例：/Users/yourname/Documents/MyVault/daily-news
OBSIDIAN_VAULT_PATH=

# ── Substack ─────────────────────────────────────────────────
# 从浏览器 DevTools 获取（Application → Cookies → substack.com）
# 详细步骤见 README.md
SUBSTACK_SID=
SUBSTACK_CONNECT_SID=
# 你的 Substack 发布地址，如 https://yourname.substack.com
SUBSTACK_PUBLICATION_URL=
